int sum(vector<int>a )
{
    int maxsum=0;
    int size=a.size();
    // cout<<size;
    for(int i=0;i<size;i++)
    {
        int sum1=0;
        for(int j=i;j<size;j++)
        {
            sum1+=a[j];
            if(sum1 > maxsum)
            {
                maxsum=sum1;
            }
        }
    }
    return maxsum ;
}



