void buildfromlevelordered(node* &root)
{
   queue<node*>qu;
   cout<<"Enter data for root"<<endl;
   int data;
   cin>>data;
   root=new node(data);
   qu.push(root);

   while(!qu.empty())
   {
      node* temp=qu.front();
      qu.pop();

      cout<<"Enter left node for : "<<temp->data<<endl;
      int leftData;
      cin>>leftData;
      if(leftData!=-1)
      {
         temp->left=new node(leftData);
         qu.push(temp->left);
      }

      cout<<"Enter right node for :"<<temp-data<<endl;
      int rightData;
      cin>>rightData;

      if(rightData !=-1)
      {
         temp->right=new node(rightData);
         qu.push(temp->right);
      }
   }
}



int main()
{
   node* root=NULL;
   root=insertdata(root);
   cout<<"Travesal : "<<endl;
   traverse(root);
   cout<<endl;


   cout<<"inorder traversal : ";
   traverse1(root);
   cout<<endl;


   cout<<"Preordered traversal ";
   preodered(root);
   cout<<endl;


   cout<<"Postordered traversal ";
   postordered(root);

   buildfromlevelordered(root);
   cout<<endl;
   cout<<"Travesal : "<<endl;
